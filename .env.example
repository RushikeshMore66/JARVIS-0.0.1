OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVEN_API_KEY=
ELEVENLABS_API_KEY=
PICOVOICE_ACCESS_KEY=

LOCAL_MODEL=llama3.2:latest
LOCAL_VISION_MODEL=llava:latest
CLOUD_MODEL=gemini-1.5-flash
WAKE_WORD=jarvis
SAMPLE_RATE=16000
CHUNK_SIZE=1024

USE_CLOUD_FALLBACK=true
ALLOW_DANGEROUS_ACTIONS=false
ENABLE_GESTURE_CONTROLLER=false
ENABLE_OVERLAY_UI=false
ENABLE_BACKGROUND_AGENTS=false
ENABLE_MCP=true
